{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "julianapradosanteaju.com.br"
        }
      ],
      "destination": "https://julianapradosanteaju.com.br/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!robots.txt|sitemap.xml).*)",
      "destination": "/index.html"
    }
  ]
}